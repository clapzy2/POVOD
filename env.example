# =================================================================================
# POVOD backend — переменные окружения
# =================================================================================
# Скопируй в .env и при необходимости поправь. Все значения имеют безопасные дефолты,
# сервер поднимается и без .env.

# Порт HTTP-сервера (локально совпадает с дефолтом rootStore фронта)
PORT=8080

# Интерфейс прослушивания
HOST=0.0.0.0

# CORS origin: "*" для разработки, конкретный домен фронта для прода
#   например: https://team-5.hack.kam-dev.ru
CORS_ORIGIN=*

# Персистентность данных в data/db.json:
#   true  — пережимать изменения на диск (по умолчанию локально)
#   false — чистый in-memory, пересев при каждом старте (по умолчанию в Docker)
PERSIST=true

# Имя сервиса (отдаётся в /health и /api/ping)
SERVICE_NAME=povod-backend

NODE_ENV=development

# --- VK Mini Apps ---
# Защищённый ключ приложения VK (из настроек приложения на vk.com/dev).
# Если задан — бэкенд проверяет подпись launch-параметров (sign) на /api/Auth/vk.
# Если пусто — подпись НЕ проверяется (дев-режим). НЕ коммитить реальное значение!
VK_APP_SECRET=
# ID приложения VK (необязательно, для справки/будущих проверок)
VK_APP_ID=
